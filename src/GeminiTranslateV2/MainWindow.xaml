<Window x:Class="GeminiTranslateV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tradutor de Reuniões — V2 (captura por processo)" Width="800" Height="680"
        Background="#1E1F22" Foreground="#EAEAEA" FontSize="13"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- API key -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="API key:" Width="150"/>
            <PasswordBox x:Name="ApiKeyBox" VerticalContentAlignment="Center"/>
        </DockPanel>

        <!-- Entrada: a process (Process Loopback) OR a render device/cable (WASAPI loopback) -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Escutar:" Grid.Column="0"
                       ToolTip="Um processo (captura só o áudio daquele app) ou um dispositivo/cabo (captura tudo que toca nele — aponte a saída do app de chamada para o cabo)."/>
            <ComboBox x:Name="SourceCombo" Grid.Column="1" Margin="0,2,6,2"/>
            <Button x:Name="RefreshSourcesButton" Content="↻" Width="28" Grid.Column="2" Click="OnRefreshSources" Margin="0,0,10,0"/>
            <TextBlock Text="Meu fone (ouço aqui):" Grid.Column="3"/>
            <ComboBox x:Name="HeadphonesCombo" Grid.Column="4"/>
        </Grid>

        <!-- Saída: my mic -> virtual mic -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Meu microfone:" Grid.Column="0"/>
            <ComboBox x:Name="MicCombo" Grid.Column="1" Margin="0,2,10,2"/>
            <TextBlock Text="Microfone virtual:" Grid.Column="2"/>
            <ComboBox x:Name="VirtualMicCombo" Grid.Column="3"/>
        </Grid>

        <!-- Languages + original volume -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Eu ouço em:" Grid.Column="0"/>
            <ComboBox x:Name="MyLangCombo" Grid.Column="1" Margin="0,2,10,2"/>
            <TextBlock Text="Eles ouvem em:" Grid.Column="2"/>
            <ComboBox x:Name="TheirLangCombo" Grid.Column="3"/>
        </Grid>

        <DockPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Voz original (fundo):" Width="150"/>
            <TextBlock x:Name="VolumeText" DockPanel.Dock="Right" Width="50" TextAlignment="Right"/>
            <Slider x:Name="VolumeSlider" Minimum="0" Maximum="0.5"
                    ValueChanged="OnVolumeChanged" VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Transcripts -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="IncomingHeader" Text="A outra pessoa" Grid.Row="0" Grid.Column="0" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="IncomingBox" Grid.Row="1" Grid.Column="0" IsReadOnly="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Background="#26282C" Foreground="#EAEAEA" BorderThickness="0" Padding="8"/>

            <TextBlock x:Name="OutgoingHeader" Text="Você" Grid.Row="0" Grid.Column="2" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="OutgoingBox" Grid.Row="1" Grid.Column="2" IsReadOnly="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Background="#26282C" Foreground="#EAEAEA" BorderThickness="0" Padding="8"/>
        </Grid>

        <!-- Controls -->
        <DockPanel Grid.Row="6" Margin="0,10,0,0">
            <Button x:Name="StartButton" Content="▶  Iniciar" Width="120" Height="34"
                    Click="OnStartStop" FontWeight="Bold"/>
            <Button x:Name="MuteButton" Content="🎙 Mic ligado" Width="120" Height="34" Margin="8,0,0,0"
                    Click="OnMuteToggle" IsEnabled="False"/>
            <TextBlock x:Name="DelayText" DockPanel.Dock="Right" Text="" Margin="14,0,0,0"
                       Foreground="#9AA0A6" ToolTip="Tradução na fila de reprodução (atraso ao vivo). ⏩ = acelerando a 1,1× para recuperar."/>
            <TextBlock x:Name="StatusText" Text="Parado" Margin="14,0,0,0" Foreground="#9AA0A6"/>
        </DockPanel>
    </Grid>
</Window>
