<Window x:Class="GeminiLiveTranslate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tradutor de Reuniões — Gemini 3.5 Live"
        Height="760" Width="1040" MinHeight="600" MinWidth="900"
        Background="{StaticResource Bg}">
    <Grid Margin="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Left: settings ===== -->
        <Border Grid.Column="0" Background="{StaticResource Panel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                <StackPanel>
                    <TextBlock Text="Tradutor de Reuniões" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Gemini 3.5 Live · voz para voz" Foreground="{StaticResource Muted}" FontSize="12" Margin="0,2,0,0"/>

                    <TextBlock Text="API key (Google AI Studio)" Style="{StaticResource Label}"/>
                    <PasswordBox x:Name="ApiKeyBox"/>

                    <!-- Incoming -->
                    <TextBlock Text="🎧 Entrada — entender a outra pessoa" Style="{StaticResource Section}"/>
                    <TextBlock Text="Áudio da reunião (capturar de)" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="MeetingDeviceCombo" SelectionChanged="OnDeviceSelectionChanged"/>
                    <TextBlock Text="Ouvir a tradução em (seu fone)" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="HeadphonesCombo" SelectionChanged="OnDeviceSelectionChanged"/>
                    <TextBlock Text="Eu quero entender em" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="IncomingLangCombo"/>

                    <!-- Outgoing -->
                    <TextBlock Text="🎙️ Saída — a outra pessoa te entender" Style="{StaticResource Section}"/>
                    <CheckBox x:Name="EnableOutgoingCheck" Content="Ativar tradução da minha voz" IsChecked="True"/>
                    <TextBlock Text="Meu microfone" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="MicCombo"/>
                    <TextBlock Text="Enviar para o microfone virtual (VB-CABLE)" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="VirtualMicCombo"/>
                    <TextBlock Text="Eles ouvem em" Style="{StaticResource Label}"/>
                    <ComboBox x:Name="OutgoingLangCombo"/>

                    <CheckBox x:Name="ContinuousCheck" Content="Streaming contínuo (melhor entonação)" IsChecked="True"/>
                    <CheckBox x:Name="DuckCheck" Content="Abaixar áudio original quando traduzir (estilo Meet)"
                              IsChecked="True" Checked="OnDuckToggled" Unchecked="OnDuckToggled"/>
                    <Grid x:Name="DuckLevelPanel" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="DuckLevelSlider" Grid.Column="0" Minimum="0" Maximum="0.6"
                                SmallChange="0.02" LargeChange="0.1" VerticalAlignment="Center"
                                ValueChanged="OnDuckLevelChanged"/>
                        <TextBlock x:Name="DuckLevelText" Grid.Column="1" Margin="8,0,0,0" MinWidth="86"
                                   VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource Muted}"
                                   Text="original a 18%"/>
                    </Grid>
                    <TextBlock Text="Volume do áudio original enquanto a tradução fala. Menor = tradução sobressai mais."
                               Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>

                    <CheckBox x:Name="AutoDefaultCheck" Content="Definir dispositivo padrão do Windows ao iniciar"
                              Margin="0,10,0,0"/>
                    <TextBlock Text="Aponta o cabo virtual como padrão do Windows enquanto traduz (e restaura ao parar), para apps como WhatsApp/Teams se ajustarem sozinhos. O Meet no navegador ainda escolhe por aba."
                               Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>

                    <Button x:Name="GuideButton" Content="❔ Como configurar Teams / Meet / WhatsApp" Click="OnShowGuide"
                            Margin="0,10,0,0" Padding="8,6" Background="{StaticResource Field}"
                            Foreground="{StaticResource Text}" BorderBrush="#44444C"/>

                    <TextBlock Text="Captura e saída precisam ser dispositivos DIFERENTES, senão a fala entra em loop."
                               Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>

                    <TextBlock x:Name="WarningText" Foreground="{StaticResource Warn}" TextWrapping="Wrap"
                               FontSize="12" Margin="0,14,0,0" Visibility="Collapsed"/>

                    <Button x:Name="RefreshButton" Content="↻ Atualizar dispositivos" Click="OnRefreshDevices"
                            Margin="0,16,0,0" Padding="8,6" Background="{StaticResource Field}"
                            Foreground="{StaticResource Text}" BorderBrush="#44444C"/>

                    <!-- Cost / budget -->
                    <TextBlock Text="💰 Custo / orçamento (estimativa)" Style="{StaticResource Section}"/>
                    <TextBlock Text="Orçamento máximo (R$)" Style="{StaticResource Label}"/>
                    <TextBox x:Name="BudgetBox" Style="{StaticResource Input}" TextChanged="OnCostFieldChanged"/>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="US$/1M entrada" Style="{StaticResource Label}"/>
                            <TextBox x:Name="PriceInBox" Style="{StaticResource Input}" TextChanged="OnCostFieldChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="US$/1M saída" Style="{StaticResource Label}"/>
                            <TextBox x:Name="PriceOutBox" Style="{StaticResource Input}" TextChanged="OnCostFieldChanged"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="O Google não expõe o gasto real em tempo real. Isto é uma estimativa a partir dos tokens × preço."
                               Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ===== Right: live ===== -->
        <Grid Grid.Column="1" Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="190"/>
            </Grid.RowDefinitions>

            <!-- Controls -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="StartButton" Grid.Column="0" Content="▶  Iniciar" Click="OnStartStop"
                        Padding="22,12" FontSize="15" FontWeight="SemiBold"
                        Background="{StaticResource Accent}" Foreground="{StaticResource AccentText}" BorderThickness="0"/>
                <Button x:Name="RecordButton" Grid.Column="1" Content="⏺ Gravar conversa" Click="OnRecordToggle"
                        IsEnabled="False" Margin="10,0,0,0" Padding="14,12" FontWeight="SemiBold"
                        Background="{StaticResource Field}" Foreground="{StaticResource Text}" BorderBrush="#44444C"
                        ToolTip="Grava a conversa traduzida num arquivo .wav estéreo (esquerda: o que você ouve · direita: o que eles ouvem)"/>
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="18,0,0,0">
                    <TextBlock x:Name="StatusText" Text="Parado" Foreground="{StaticResource Muted}"/>
                    <TextBlock x:Name="CostText" Margin="0,4,0,0" FontWeight="SemiBold"
                               Text="US$ 0,0000  ·  R$ 0,00"/>
                    <ProgressBar x:Name="BudgetBar" Height="5" Minimum="0" Maximum="1" Margin="0,4,0,0"
                                 Foreground="{StaticResource Warn}" Background="{StaticResource Field}" BorderThickness="0"/>
                    <TextBlock x:Name="BudgetText" Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource Muted}"
                               Text="Defina um orçamento à esquerda · tokens 0"/>
                </StackPanel>
            </Grid>

            <!-- Meters -->
            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Nível — outra pessoa" Foreground="{StaticResource Muted}" FontSize="11"/>
                    <ProgressBar x:Name="IncomingMeter" Height="6" Minimum="0" Maximum="1" Margin="0,4,0,0"
                                 Foreground="{StaticResource Accent}" Background="{StaticResource Field}" BorderThickness="0"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Nível — você" Foreground="{StaticResource Muted}" FontSize="11"/>
                    <ProgressBar x:Name="OutgoingMeter" Height="6" Minimum="0" Maximum="1" Margin="0,4,0,0"
                                 Foreground="#5BD08D" Background="{StaticResource Field}" BorderThickness="0"/>
                </StackPanel>
            </Grid>

            <!-- Incoming transcript -->
            <DockPanel Grid.Row="2" Margin="0,18,0,0">
                <TextBlock x:Name="IncomingHeader" DockPanel.Dock="Top" Text="A outra pessoa"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox x:Name="IncomingTranscript" Style="{StaticResource TranscriptBox}"/>
            </DockPanel>

            <!-- Outgoing transcript -->
            <DockPanel Grid.Row="3" Margin="0,14,0,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Button x:Name="TalkButton" DockPanel.Dock="Right" Content="🎤 Segure para falar (ESPAÇO)"
                            Padding="12,6" FontWeight="SemiBold" IsEnabled="False"
                            Background="{StaticResource Field}" Foreground="{StaticResource Text}" BorderBrush="#44444C"
                            PreviewMouseLeftButtonDown="OnTalkDown" PreviewMouseLeftButtonUp="OnTalkUp"
                            MouseLeave="OnTalkLeave"/>
                    <TextBlock x:Name="OutgoingHeader" Text="Você" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBox x:Name="OutgoingTranscript" Style="{StaticResource TranscriptBox}"/>
            </DockPanel>

            <!-- Live log -->
            <DockPanel Grid.Row="4" Margin="0,14,0,0">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <TextBlock Text="Log ao vivo" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <CheckBox x:Name="AutoScrollLog" Content="Auto-rolar" IsChecked="True"
                                  Margin="0" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                        <Button Content="Copiar" Click="OnCopyLog" Margin="10,0,0,0" Padding="8,3"
                                Background="{StaticResource Field}" Foreground="{StaticResource Text}" BorderBrush="#44444C"/>
                        <Button Content="📄 Abrir pasta" Click="OnOpenLogFolder" Margin="8,0,0,0" Padding="8,3"
                                Background="{StaticResource Field}" Foreground="{StaticResource Text}" BorderBrush="#44444C"/>
                    </StackPanel>
                </Grid>
                <TextBox x:Name="LogBox" Style="{StaticResource TranscriptBox}"
                         FontFamily="Consolas" FontSize="11"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
